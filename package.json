{
  "name": "cube-craft",
  "version": "0.0.1",
  "description": "Cube Craft – a voxel block-building game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.cubecraft.game",
    "productName": "Cube Craft",
    "files": [
      "main.js",
      "server.js",
      "cube-craft.html",
      "assets/**",
      "node_modules/three/build/**",
      "node_modules/three/examples/jsm/**"
    ],
    "icon": "assets/icon",
    "mac": {
      "category": "public.app-category.games",
      "identity": null,
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Cube Craft",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    }
  },
  "dependencies": {
    "three": "0.160.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "allowScripts": {
    "electron@28.3.3": true
  }
}
